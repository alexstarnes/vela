# === Required ===
# Supabase — Transaction-mode pooler URL (used by the app at runtime)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase — Direct connection URL (used by drizzle-kit for migrations only)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

ANTHROPIC_API_KEY=sk-ant-...
VELA_PASSWORD=your-secure-password-here

# === Local Models ===
# Cloudflare Tunnel URL pointing to local Ollama instance
# Leave empty if not using local models
# Run: cloudflared tunnel --url http://localhost:11434
OLLAMA_TUNNEL_URL=https://your-tunnel.trycloudflare.com

# === Optional ===
OPENAI_API_KEY=sk-...
NODE_ENV=development
PORT=3000
