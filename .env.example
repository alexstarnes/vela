# === Required ===
# Supabase — Transaction-mode pooler URL (used by the app at runtime)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase — Direct connection URL (used by drizzle-kit for migrations only)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

ANTHROPIC_API_KEY=sk-ant-...
VELA_PASSWORD=your-secure-password-here
APP_URL=http://localhost:3000
GITHUB_CLIENT_ID=Iv1.your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-secret
VELA_HELPER_SECRET=replace-with-a-long-random-shared-secret
VELA_HELPER_URL=http://127.0.0.1:4312

# === Local Models ===
# Cloudflare Tunnel URL pointing to local Ollama instance
# Leave empty if not using local models
# Run: cloudflared tunnel --url http://localhost:11434
OLLAMA_TUNNEL_URL=https://your-tunnel.trycloudflare.com

# === Free Cloud Models (Billdun) ===
# Billdun free inference endpoint — preferred over paid when local Ollama is offline
BILLDUN_API_URL=https://billdun.com/v1
BILLDUN_API_KEY=

# === Optional ===
OPENAI_API_KEY=sk-...
PORT=3000

# Next.js sets NODE_ENV automatically.
# Do not set NODE_ENV manually in Railway or other deployments.
